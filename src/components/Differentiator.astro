---
const comparisons = [
  { feature: 'Infinite loops', feynman: 'No termination guarantee', hilbert: 'Fixed N rounds + mandatory synthesis gate' },
  { feature: 'Resume', feynman: 'No', hilbert: 'SQLite checkpoint' },
  { feature: 'Open APIs', feynman: 'AlphaXiv (proprietary)', hilbert: 'ArXiv + Semantic Scholar' },
  { feature: 'BibTeX', feynman: 'No', hilbert: 'Auto-export' },
  { feature: 'Live UI', feynman: 'No', hilbert: 'Rich panels' },
];
---

<section class="py-12 border-t border-border" id="differentiator">
  <div class="mx-auto max-w-4xl px-4 md:px-6">
    <h2 class="font-display text-3xl md:text-4xl text-foreground">
      Fixed rounds. Zero infinite loops.
    </h2>
    <p class="mt-4 text-lg text-muted-foreground">
      Same research power. Proper engineering under the hood.
    </p>
    <div class="mt-8 overflow-x-auto rounded-lg border border-border">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-border bg-muted">
            <th class="px-4 py-3 text-left font-medium text-muted-foreground">Problem</th>
            <th class="px-4 py-3 text-left font-medium text-muted-foreground">Feynman</th>
            <th class="px-4 py-3 text-left font-medium text-primary">Hilbert</th>
          </tr>
        </thead>
        <tbody>
          {comparisons.map((item, index) => (
            <tr class:list={['border-b border-border', index === comparisons.length - 1 && 'border-0']}>
              <td class="px-4 py-3 font-medium text-foreground">{item.feature}</td>
              <td class="px-4 py-3 text-muted-foreground">{item.feynman}</td>
              <td class="px-4 py-3 font-medium text-primary">{item.hilbert}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</section>