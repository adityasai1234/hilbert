---
const comparisons = [
  { feature: 'Infinite loops', feynman: 'No termination guarantee', hilbert: 'Fixed N rounds + mandatory synthesis gate' },
  { feature: 'Resume', feynman: 'No', hilbert: 'SQLite checkpoint' },
  { feature: 'Open APIs', feynman: 'AlphaXiv (proprietary)', hilbert: 'ArXiv + Semantic Scholar' },
  { feature: 'BibTeX', feynman: 'No', hilbert: 'Auto-export' },
  { feature: 'Live UI', feynman: 'No', hilbert: 'Rich panels' },
];
---

<section class="py-20" id="differentiator">
  <div class="mx-auto max-w-6xl px-4 md:px-6">
    <h2 class="mb-4 font-display text-4xl tracking-wider text-foreground">
      Fixed rounds. Zero infinite loops.
    </h2>
    <p class="mb-12 text-lg text-muted-foreground">
      Same research power. Proper engineering under the hood.
    </p>
    <div class="overflow-x-auto rounded-lg border border-border">
      <table class="w-full">
        <thead>
          <tr class="border-b border-border bg-muted/50">
            <th class="px-4 py-3 text-left text-sm font-medium text-muted-foreground">Problem</th>
            <th class="px-4 py-3 text-left text-sm font-medium text-muted-foreground">Feynman</th>
            <th class="px-4 py-3 text-left text-sm font-medium text-primary">Hilbert</th>
          </tr>
        </thead>
        <tbody>
          {comparisons.map((item, index) => (
            <tr class:list={['border-b border-border', index === comparisons.length - 1 && 'border-0']}>
              <td class="px-4 py-4 text-sm font-medium text-foreground">{item.feature}</td>
              <td class="px-4 py-4 text-sm text-muted-foreground">{item.feynman}</td>
              <td class="px-4 py-4 text-sm font-medium text-primary">{item.hilbert}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</section>