---
const workflows = [
  { command: '/deepresearch', description: 'Fixed N rounds with synthesis gate' },
  { command: '/lit', description: 'Literature review with consensus mapping' },
  { command: '/review', description: 'Simulated peer review with severity scores' },
  { command: '/compare', description: 'Side-by-side source comparison' },
  { command: '/audit', description: 'Paper claims vs. code audit' },
  { command: '/replicate', description: 'Reproduce published experiments' },
];

const agents = [
  { name: 'Researcher', description: 'Hunts for evidence across papers, the web, repos, and docs' },
  { name: 'Reviewer', description: 'Grades claims by severity, flags gaps, and suggests revisions' },
  { name: 'Writer', description: 'Structures notes into briefs, drafts, and paper-style output' },
  { name: 'Verifier', description: 'Checks every citation, verifies URLs, removes dead links' },
];

const tools = [
  { name: 'ArXiv', description: 'Open paper search and metadata' },
  { name: 'Semantic Scholar', description: 'Open academic search API' },
  { name: 'Web Search', description: 'General web queries' },
  { name: 'Session Search', description: 'Indexed recall across prior research sessions' },
  { name: 'Preview', description: 'Browser and PDF export of generated artifacts' },
];

const artifacts = [
  { file: 'report.md', description: 'Markdown with inline citations' },
  { file: 'report.json', description: 'Structured JSON' },
  { file: 'report.bib', description: 'BibTeX bibliography' },
  { file: 'report.tex', description: 'LaTeX article' },
  { file: 'report.mmd', description: 'Mermaid knowledge graph' },
];
---

<section class="py-12" id="workflows">
  <div class="mx-auto max-w-4xl px-4 md:px-6">
    <div class="grid gap-12 md:grid-cols-2">
      <div>
        <h2 class="font-display text-2xl text-foreground">Workflows</h2>
        <p class="mt-2 text-muted-foreground">Slash commands or natural language. Your call.</p>
        <div class="mt-6 space-y-2">
          {workflows.map(wf => (
            <div class="flex items-center gap-3 p-2 rounded">
              <code class="font-mono text-sm text-primary">{wf.command}</code>
              <span class="text-sm text-muted-foreground">{wf.description}</span>
            </div>
          ))}
        </div>
      </div>
      <div>
        <h2 class="font-display text-2xl text-foreground">Agents</h2>
        <p class="mt-2 text-muted-foreground">You ask a question. The right team assembles.</p>
        <div class="mt-6 space-y-4">
          {agents.map(agent => (
            <div>
              <h3 class="font-medium text-foreground">{agent.name}</h3>
              <p class="text-sm text-muted-foreground">{agent.description}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<section class="py-12 section-muted" id="agents">
  <div class="mx-auto max-w-4xl px-4 md:px-6">
    <div class="grid gap-12 md:grid-cols-2">
      <div id="skills">
        <h2 class="font-display text-2xl text-foreground">Skills & Tools</h2>
        <p class="mt-2 text-muted-foreground">How Hilbert searches, remembers, and exports work.</p>
        <div class="mt-6 grid gap-3 sm:grid-cols-2">
          {tools.map(tool => (
            <div class="p-3 rounded-md card">
              <h3 class="font-medium text-foreground">{tool.name}</h3>
              <p class="text-sm text-muted-foreground">{tool.description}</p>
            </div>
          ))}
        </div>
      </div>
      <div>
        <h2 class="font-display text-2xl text-foreground">Output Artifacts</h2>
        <p class="mt-2 text-muted-foreground">Every research session produces usable exports.</p>
        <div class="mt-6 space-y-2">
          {artifacts.map(artifact => (
            <div class="flex items-center gap-3">
              <code class="font-mono text-sm text-primary">{artifact.file}</code>
              <span class="text-sm text-muted-foreground">{artifact.description}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>