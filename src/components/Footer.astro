---
const footerLinks = [
  { href: '/docs', label: 'Docs' },
  { href: 'https://github.com', label: 'GitHub' },
  { href: '/docs/getting-started/installation', label: 'Installation' },
];
---

<footer class="border-t border-border py-12">
  <div class="mx-auto max-w-6xl px-4 md:px-6">
    <div class="flex flex-col items-center justify-between gap-6 md:flex-row">
      <div class="flex flex-col items-center gap-2 md:items-start">
        <span class="font-display text-2xl tracking-wider text-foreground">hilbert</span>
        <p class="text-sm text-muted-foreground">
          Open source AI research agent with termination guarantees.
        </p>
      </div>
      <div class="flex gap-6">
        {footerLinks.map(link => (
          <a href={link.href} class="text-sm text-muted-foreground hover:text-foreground transition-colors">
            {link.label}
          </a>
        ))}
      </div>
    </div>
    <div class="mt-8 text-center text-sm text-muted-foreground md:text-left">
      © {new Date().getFullYear()} Hilbert. MIT License.
    </div>
  </div>
</footer>