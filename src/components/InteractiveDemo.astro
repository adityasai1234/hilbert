---
const examples = [
  {
    input: 'hilbert "federated learning challenges"',
    output: 'Cited research brief + report.bib + report.mmd',
    description: 'Quick research on any topic',
  },
  {
    input: 'hilbert deepresearch "mechanistic interpretability"',
    output: 'Multi-agent deep dive with synthesis',
    description: 'Deep investigation with verification',
  },
  {
    input: 'hilbert continue abc123',
    output: 'Resumes from SQLite checkpoint',
    description: 'Crash recovery - pick up where you left off',
  },
  {
    input: 'hilbert diff session-a session-b',
    output: 'Side-by-side comparison matrix',
    description: 'Compare two research sessions',
  },
];
---

<section class="py-20 bg-muted/30" id="what-you-type">
  <div class="mx-auto max-w-6xl px-4 md:px-6">
    <h2 class="mb-4 font-display text-4xl tracking-wider text-foreground">
      What you type → what happens
    </h2>
    <p class="mb-12 text-lg text-muted-foreground">
      Ask a question or run a workflow. Every answer is cited.
    </p>
    <div class="grid gap-6 md:grid-cols-2">
      {examples.map(example => (
        <div class="group rounded-lg border border-border bg-card p-5 transition-colors hover:border-primary/50">
          <div class="mb-3">
            <code class="font-mono text-sm text-foreground">{example.input}</code>
          </div>
          <div class="mb-3 text-muted-foreground">
            <span class="text-primary">→</span> {example.output}
          </div>
          <p class="text-sm text-muted-foreground">{example.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>