---
const examples = [
  { input: 'hilbert "federated learning challenges"', output: 'Cited research brief + report.bib + report.mmd' },
  { input: 'hilbert deepresearch "mechanistic interpretability"', output: 'Multi-agent deep dive with synthesis' },
  { input: 'hilbert continue abc123', output: 'Resumes from SQLite checkpoint' },
  { input: 'hilbert diff session-a session-b', output: 'Side-by-side comparison matrix' },
];
---

<section class="py-12 bg-muted/30" id="what-you-type">
  <div class="mx-auto max-w-4xl px-4 md:px-6">
    <h2 class="font-display text-3xl md:text-4xl text-foreground">
      What you type → what happens
    </h2>
    <p class="mt-4 text-lg text-muted-foreground">
      Ask a question or run a workflow. Every answer is cited.
    </p>
    <div class="mt-8 space-y-3">
      {examples.map(example => (
        <div class="flex flex-col sm:flex-row sm:items-center gap-2 sm:gap-4 p-3 rounded-md border border-border bg-card">
          <code class="font-mono text-sm text-foreground whitespace-nowrap">{example.input}</code>
          <span class="text-primary hidden sm:block">→</span>
          <span class="text-sm text-muted-foreground">{example.output}</span>
        </div>
      ))}
    </div>
  </div>
</section>